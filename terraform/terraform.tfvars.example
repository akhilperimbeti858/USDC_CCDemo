# Copy to terraform.tfvars and fill in your values.

aws_region     = "us-east-1"
project_name   = "usdc-ner"
s3_bucket_name = "usdc-ner-groundtruth-REPLACE-WITH-UNIQUE-SUFFIX"

# ARN of an existing private workteam (created in the SageMaker / Ground Truth console).
private_workteam_arn = "arn:aws:sagemaker:us-east-1:111122223333:workteam/private-crowd/my-team"

label_attribute_name = "ner-labels"
entity_labels        = ["OFAC_ORG", "OFAC_POI", "FTO"]

# 'single' -> single-worker pass-through consolidation (set workers = 1)
# 'merge'  -> multi-worker span-merge consolidation  (set workers > 1)
consolidation_mode                 = "single"
number_of_human_workers_per_object = 1
